{
  "name": "swiyu-trust-management-ui",
  "version": "3.19.2",
  "private": true,
  "scripts": {
    "build": "ng build",
    "build-dev": "ng build -c development",
    "build-prod": "ng build -c production",
    "format": "ng lint --fix && npm run prettier",
    "pregenerate:api": "rimraf src/app/api/generated",
    "generate:api": "HTTPS_PROXY=\"\" NODE_TLS_REJECT_UNAUTHORIZED='0' openapi-generator-cli generate --generator-key angular-client-api",
    "postgenerate:api": "./node_modules/.bin/prettier --write \"src/app/api/generated/**/*.ts\"",
    "generate:translations": "ngx-translate-extract --sort --input ./src/app --output ./src/assets/i18n/{de,fr,it}.json --clean --format json",
    "postgenerate:translations": "./node_modules/.bin/prettier --write \"src/assets/i18n/*.json\"",
    "lint": "ng lint",
    "prettier": "prettier --write \"src/**/*.{ts,html,scss,json,js}\"",
    "start": "ng serve",
    "test": "ng test",
    "test:ci": "ng test --watch=false --run-in-band --force-exit --collect-coverage=true",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "^20.3.10",
    "@angular/cdk": "^20.2.12",
    "@angular/common": "^20.3.10",
    "@angular/compiler": "^20.3.10",
    "@angular/core": "^20.3.10",
    "@angular/forms": "^20.3.10",
    "@angular/material": "^20.2.12",
    "@angular/platform-browser": "^20.3.10",
    "@angular/platform-browser-dynamic": "^20.3.10",
    "@angular/router": "^20.3.10",
    "@ngx-translate/core": "^16.0.4",
    "@oblique/oblique": "^14.0.2",
    "@openapitools/openapi-generator-cli": "^2.18.4",
    "@popperjs/core": "^2.0.0",
    "angular-oauth2-oidc": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular-devkit/core": "^20.3.9",
    "@angular/build": "^20.3.9",
    "@angular/cli": "^20.3.9",
    "@angular/compiler-cli": "^20.3.10",
    "@types/jest": "^29.0.0",
    "@vendure/ngx-translate-extract": "^9.4.2",
    "ajv": "^8.0.0",
    "ajv-formats": "^3.0.1",
    "angular-eslint": "20.6.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "jest-sonar-reporter": "^2.0.0",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-json": "^4.1.1",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  }
}
